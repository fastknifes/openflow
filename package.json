{
  "name": "@fastknife/openflow",
  "version": "0.1.0",
  "description": "OpenFlow - document-as-constraint governance for AI-driven OpenCode development",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "npm run clean && tsc",
    "dev": "tsc --watch",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "opencode",
    "plugin",
    "workflow",
    "devflow",
    "tdd",
    "archive"
  ],
  "author": "fastknife <2777314125@qq.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fastknifes/openflow.git"
  },
  "dependencies": {
    "zod": "^3.22.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "latest",
    "@types/node": "^25.4.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ]
}
